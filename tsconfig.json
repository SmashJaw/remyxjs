{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@remyx/core": ["remyx-core/src/index.js"],
      "@remyx/react": ["remyx-react/src/index.js"]
    }
  },
  "include": [
    "remyx-core/src/**/*",
    "remyx-react/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
